{
    "name": "examsys/backend",
    "description": "Exam system PHP backend API",
    "type": "project",
    "require": {
        "php": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "smoke-test": "php tests/SecuritySmokeTest.php",
        "exam-validation-test": "php tests/ExamValidationTest.php",
        "encryption-storage-test": "php tests/EncryptionStorageCompatibilityTest.php",
        "repair-encrypted-storage": "php scripts/repair_encrypted_storage.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
