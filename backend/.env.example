DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=examhub
DB_USER=root
DB_PASS=
DB_SSL_MODE=
DB_SSL_CA=

LOG_DB_HOST=127.0.0.1
LOG_DB_PORT=3306
LOG_DB_NAME=examhub_logs
LOG_DB_USER=root
LOG_DB_PASS=
LOG_DB_SSL_MODE=
LOG_DB_SSL_CA=
LOG_RETENTION_DAYS=90

APP_JWT_SECRET=replace-with-strong-random-secret
# 32-byte AES key. Supported formats: raw 32-byte, plain base64, base64:<...>, or 64-char hex.
# Recommended format:
# APP_ENCRYPTION_KEY=base64:<44-char-base64-that-decodes-to-32-bytes>
APP_ENCRYPTION_KEY=base64:MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
AUTH_TOKEN_TTL_SECONDS=28800
CORS_ALLOW_ALL=true
# Comma-separated list used when CORS_ALLOW_ALL=false.
# Example: CORS_ALLOWED_ORIGINS=https://your-vercel-site.vercel.app,https://www.example.com
CORS_ALLOWED_ORIGINS=

# Seed accounts (required on fresh DB). Keep real values only in local backend/.env
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_DEPARTMENT=Administration

SEED_TEACHER_NAME=Seed Teacher
SEED_TEACHER_EMAIL=
SEED_TEACHER_PASSWORD=
SEED_TEACHER_DEPARTMENT=Education

SEED_STUDENT_NAME=Seed Student
SEED_STUDENT_EMAIL=
SEED_STUDENT_PASSWORD=
SEED_STUDENT_DEPARTMENT=General Studies
