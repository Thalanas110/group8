DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=examhub
DB_USER=root
DB_PASS=

LOG_DB_HOST=127.0.0.1
LOG_DB_PORT=3306
LOG_DB_NAME=examhub_logs
LOG_DB_USER=root
LOG_DB_PASS=
LOG_RETENTION_DAYS=90

APP_JWT_SECRET=replace-with-strong-random-secret
APP_ENCRYPTION_KEY=replace-with-strong-32-byte-key-or-base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=
AUTH_TOKEN_TTL_SECONDS=28800
CORS_ALLOW_ALL=true

# Seed accounts (required on fresh DB). Keep real values only in local backend/.env
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_DEPARTMENT=Administration

SEED_TEACHER_NAME=Seed Teacher
SEED_TEACHER_EMAIL=
SEED_TEACHER_PASSWORD=
SEED_TEACHER_DEPARTMENT=Education

SEED_STUDENT_NAME=Seed Student
SEED_STUDENT_EMAIL=
SEED_STUDENT_PASSWORD=
SEED_STUDENT_DEPARTMENT=General Studies
